{
  "name": "Monkey D' Bryan",
  "description": "Bot de segurança, avaliação de perfil, autoMod e comandos administrativos.",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "node index.js"
  },
  "author": "Bryan",
  "license": "MIT",
  "dependencies": {
    "discord.js": "^14.13.0",
    "mongoose": "^7.6.0",
    "@discordjs/rest": "^1.7.0",
    "discord-api-types": "^0.37.49"
  },
  "env": {
    "TOKEN": "Seu_Token_Aqui",
    "CLIENT_ID": "Seu_ClientID_Aqui",
